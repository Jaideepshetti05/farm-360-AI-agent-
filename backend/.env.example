# ──────────────────────────────────────────────────────────────────────────────
# Farm360 AI — Backend Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] API key for the Farm360 backend. Used to authenticate frontend requests.
# If not set, a random temporary key will be generated on each startup.
FARM360_API_KEY=your-secret-api-key-here

# [REQUIRED for AI chat] OpenRouter API key for LLM access.
# Get one at: https://openrouter.ai/keys
# If not set, the agent falls back to deterministic (knowledge-base) responses.
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# [OPTIONAL] OpenWeather API key for real weather data.
# Get one at: https://openweathermap.org/api
# If not set, the agent returns mock weather data.
OPENWEATHER_API_KEY=

# [OPTIONAL] Base path for ML model files.
# Defaults to the project root directory.
# In Docker, this is typically /app.
MODEL_BASE_PATH=

# [OPTIONAL] CORS allowed origins (comma-separated).
# Defaults to * (allow all). In production, set to your frontend domain.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
