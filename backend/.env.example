# ══════════════════════════════════════════════════════════════════════════════
# Farm360 AI — Backend Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# MULTI-KEY SUPPORT
#   You can add up to 5 Gemini keys, 5 OpenRouter keys, and 3 OpenAI keys.
#   The system auto-rotates on rate-limit / auth errors, cooling a failed key
#   for 60 seconds before retrying. Provider priority: Gemini → OpenRouter → OpenAI.
#   Leave unused slots blank — they are safely ignored.
# ══════════════════════════════════════════════════════════════════════════════

# =========================
# GOOGLE GEMINI KEYS
# =========================
# Get keys at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY_1=
GOOGLE_API_KEY_2=
GOOGLE_API_KEY_3=
GOOGLE_API_KEY_4=
GOOGLE_API_KEY_5=

# =========================
# OPENROUTER KEYS
# =========================
# Get keys at: https://openrouter.ai/keys
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=
OPENROUTER_API_KEY_3=
OPENROUTER_API_KEY_4=
OPENROUTER_API_KEY_5=

# =========================
# OPTIONAL OPENAI KEYS
# =========================
# Get keys at: https://platform.openai.com/api-keys
OPENAI_API_KEY_1=
OPENAI_API_KEY_2=
OPENAI_API_KEY_3=

# =========================
# APPLICATION KEY
# =========================
# [REQUIRED] Used to authenticate frontend → backend requests.
# If not set, a random temporary key is generated on each startup.
FARM360_API_KEY=your-secret-key-here

# =========================
# OPTIONAL SETTINGS
# =========================
# OpenWeather API key for live weather data (https://openweathermap.org/api)
OPENWEATHER_API_KEY=

# Base path for ML model files. Defaults to project root.
MODEL_BASE_PATH=

# CORS allowed origins (comma-separated). Defaults to * (allow all).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
