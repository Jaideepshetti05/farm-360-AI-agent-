# Farm360 Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Google Gemini API Key (get from https://aistudio.google.com/apikey)
# Leave blank to run in deterministic fallback mode
GOOGLE_API_KEY=your_actual_google_gemini_api_key_here

# Custom API Key for securing Farm360 backend endpoints
# Must match NEXT_PUBLIC_FARM360_API_KEY in the frontend .env.local
FARM360_API_KEY=your_custom_secret_key_here
